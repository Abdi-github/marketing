    "@marketing/db": "workspace:*",
    "@marketing/shared": "workspace:*",
    "@marketing/tenancy": "workspace:*",
    "bullmq": "^5.34.3",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.0",
    "@types/node": "^22.10.2",
    "drizzle-orm": "^0.36.4",
    "esbuild": "^0.28.0",
    "postgres": "^3.4.9",
    "testcontainers": "^12.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  }
