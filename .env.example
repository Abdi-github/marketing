# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored — NEVER commit real secrets.
#
# Strategy:
#   - This file (.env.example) is committed: safe placeholders, no real values.
#   - .env.local is loaded automatically by Next.js (apps/web) and must be
#     created manually on each machine / CI secret store / Vercel env panel.
#   - packages/shared/src/env.ts is the SINGLE SOURCE OF TRUTH for which vars
#     are valid. Any var not declared there is invisible to app code.
#   - Required vars without defaults will throw at startup if missing.
#   - Optional vars (marked below) are safe to omit in local dev until the
#     phase that needs them.

# ─── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Postgres 16. Use Docker locally: docker compose up -d db
DATABASE_URL=postgres://postgres:postgres@localhost:5432/marketing_dev

# ─── Redis / Queue ────────────────────────────────────────────────────────────
# BullMQ queue backend. Use Docker locally: docker compose up -d redis
REDIS_URL=redis://localhost:6379

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Auth — Better-Auth (Phase 3+, required) ──────────────────────────────────
# Generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
# Full public URL of the web app (no trailing slash)
BETTER_AUTH_URL=http://localhost:3000

# ─── Email — Resend primary (Phase 4, optional until step-10) ─────────────────
# https://resend.com → API Keys
# RESEND_API_KEY=re_REPLACE_WITH_YOUR_KEY

# ─── Email — Postmark fallback (Phase 4, optional) ────────────────────────────
# https://account.postmarkapp.com → API Tokens
# POSTMARK_API_KEY=REPLACE_WITH_YOUR_KEY

# ─── AI — Anthropic Claude primary (Phase 4, optional until step-10) ──────────
# https://console.anthropic.com → API Keys
# Primary text model: claude-sonnet-4-6 (content), claude-haiku-4-5 (eval/routing)
# ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY

# ─── AI — OpenAI fallback (Phase 4, optional) ─────────────────────────────────
# https://platform.openai.com → API keys
# Activated only when Anthropic circuit-breaker opens (ProviderRouter)
# OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_KEY

# ─── AI — Replicate / FLUX image generation (Phase 4, optional until step-10) ─
# https://replicate.com → Account → API tokens
# FLUX.1 [schnell] for drafts ($0.003/image), [pro] for finals ($0.05/image)
# REPLICATE_API_TOKEN=r8_REPLACE_WITH_YOUR_TOKEN

# ─── AI Observability — Langfuse (Phase 4, optional) ─────────────────────────
# Self-hosted or cloud: https://langfuse.com
# LANGFUSE_PUBLIC_KEY=pk-lf-REPLACE_WITH_YOUR_KEY
# LANGFUSE_SECRET_KEY=sk-lf-REPLACE_WITH_YOUR_KEY
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ─── App Observability — OpenTelemetry (Phase 4+, optional) ───────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=marketing-web

# ─── Object Storage — Scaleway (CH-resident, Phase 2+, optional) ──────────────
# https://console.scaleway.com → Object Storage → Credentials
# Region: fr-par (Paris, EU) or nl-ams (Amsterdam, EU)
# SCALEWAY_ACCESS_KEY=REPLACE_WITH_YOUR_KEY
# SCALEWAY_SECRET_KEY=REPLACE_WITH_YOUR_SECRET
# SCALEWAY_BUCKET_NAME=marketing-assets
# SCALEWAY_REGION=fr-par
# SCALEWAY_ENDPOINT=https://s3.fr-par.scw.cloud
# SCW_DEFAULT_ORGANIZATION_ID=REPLACE_WITH_YOUR_ORG_ID
# SCW_DEFAULT_PROJECT_ID=REPLACE_WITH_YOUR_PROJECT_ID

# Custom domains / HTTPS certificates.
# Local default is stub. Production should use fly or webhook; manual fails visibly.
# DOMAIN_CERT_PROVIDER=stub
# DOMAIN_CERT_ALLOW_STUB=false
# Fly.io provider:
# FLY_API_TOKEN=FlyV1_REPLACE_WITH_YOUR_TOKEN
# FLY_APP_NAME=marketing-web
# FLY_APP_ID=REPLACE_WITH_FLY_GRAPHQL_APP_ID
# Webhook provider for a dedicated edge/cert service:
# DOMAIN_CERT_WEBHOOK_URL=https://edge.example.com/internal/domain-cert
# DOMAIN_CERT_WEBHOOK_SECRET=REPLACE_WITH_HMAC_SECRET

# ─── Billing — Stripe (Phase 5, optional until billing step) ──────────────────
# https://dashboard.stripe.com → Developers → API keys
# Use test-mode keys (sk_test_...) locally; live keys only in production.
# STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY
# STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_SECRET
# Next.js build-time public key (prefix NEXT_PUBLIC_ required by Next.js):
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_KEY

# ─── Phase 6+ integrations (all optional, do not set until the phase ships) ───
# Google Business Profile OAuth (Phase 6)
# GBP_OAUTH_CLIENT_ID=REPLACE
# GBP_OAUTH_CLIENT_SECRET=REPLACE
#
# Meta (Facebook + Instagram) OAuth — requires App Review (Phase 6-7)
# META_APP_ID=REPLACE
# META_APP_SECRET=REPLACE
# META_WEBHOOK_VERIFY_TOKEN=REPLACE
#
# WhatsApp Cloud API MVP test mode (single tenant, Meta test number).
# Use this only until you register a real WhatsApp Business number.
# Callback URL:
# https://marketing-web-pied-nine.vercel.app/api/integrations/meta/whatsapp/callback
# WHATSAPP_ACCESS_TOKEN=REPLACE_WITH_TEMPORARY_OR_PERMANENT_TOKEN
# WHATSAPP_PHONE_NUMBER_ID=REPLACE_WITH_META_PHONE_NUMBER_ID
# WHATSAPP_VERIFY_TOKEN=marketing-wa-verify
# WHATSAPP_TEST_MODE_ENABLED=true
# WHATSAPP_TEST_TENANT_SLUG=your-tenant-slug
#
# Cloudflare API token (Phase 6 — landing page DNS)
# CLOUDFLARE_API_TOKEN=REPLACE
# CLOUDFLARE_ZONE_ID=REPLACE
